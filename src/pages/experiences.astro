---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Experiences">
<section class="bg-primary text-white py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">Experiences We've Crafted</h1>
      <p class="text-xl md:text-2xl text-blue-100 max-w-3xl mx-auto">Discover the extraordinary journeys we've designed for travelers seeking unforgettable adventures around the world</p>
    </div>
  </div>
</section>

<section class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Featured Experiences</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">Each journey is meticulously crafted to create lasting memories and exceed expectations</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="card bg-white shadow-xl border border-slate-100 rounded-2xl overflow-hidden group hover:shadow-2xl transition-all duration-300">
        <figure class="overflow-hidden">
          <img src="https://placehold.co/400x250/10b981/ffffff?text=Bali+Luxury" alt="Bali Luxury Escape" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-300">
        </figure>
        <div class="card-body p-6">
          <h3 class="card-title text-slate-900 text-xl mb-2">Bali Luxury Escape</h3>
          <p class="text-slate-600 mb-4">7 days of pure indulgence in private villas, spa treatments, and cultural immersion in the Island of Gods</p>
          <div class="flex items-center justify-between">
            <span class="badge badge-primary">Luxury</span>
            <span class="text-sm text-slate-500">7 Days</span>
          </div>
        </div>
      </div>

      <div class="card bg-white shadow-xl border border-slate-100 rounded-2xl overflow-hidden group hover:shadow-2xl transition-all duration-300">
        <figure class="overflow-hidden">
          <img src="https://placehold.co/400x250/0ea5e9/ffffff?text=Maldives+Romance" alt="Maldives Honeymoon Retreat" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-300">
        </figure>
        <div class="card-body p-6">
          <h3 class="card-title text-slate-900 text-xl mb-2">Maldives Honeymoon Retreat</h3>
          <p class="text-slate-600 mb-4">Romantic overwater bungalows, private dining, and crystal-clear waters for the perfect honeymoon</p>
          <div class="flex items-center justify-between">
            <span class="badge badge-secondary">Romance</span>
            <span class="text-sm text-slate-500">5 Days</span>
          </div>
        </div>
      </div>

      <div class="card bg-white shadow-xl border border-slate-100 rounded-2xl overflow-hidden group hover:shadow-2xl transition-all duration-300">
        <figure class="overflow-hidden">
          <img src="https://placehold.co/400x250/f59e0b/ffffff?text=Dubai+Adventure" alt="Dubai Adventure Trip" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-300">
        </figure>
        <div class="card-body p-6">
          <h3 class="card-title text-slate-900 text-xl mb-2">Dubai Adventure Trip</h3>
          <p class="text-slate-600 mb-4">Thrilling desert safaris, luxury shopping, and architectural marvels in the city of gold</p>
          <div class="flex items-center justify-between">
            <span class="badge badge-accent">Adventure</span>
            <span class="text-sm text-slate-500">6 Days</span>
          </div>
        </div>
      </div>

      <div class="card bg-white shadow-xl border border-slate-100 rounded-2xl overflow-hidden group hover:shadow-2xl transition-all duration-300">
        <figure class="overflow-hidden">
          <img src="https://placehold.co/400x250/84cc16/ffffff?text=Thailand+Islands" alt="Thailand Island Tour" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-300">
        </figure>
        <div class="card-body p-6">
          <h3 class="card-title text-slate-900 text-xl mb-2">Thailand Island Tour</h3>
          <p class="text-slate-600 mb-4">Island hopping adventure through pristine beaches, vibrant culture, and delicious cuisine</p>
          <div class="flex items-center justify-between">
            <span class="badge badge-success">Culture</span>
            <span class="text-sm text-slate-500">8 Days</span>
          </div>
        </div>
      </div>

      <div class="card bg-white shadow-xl border border-slate-100 rounded-2xl overflow-hidden group hover:shadow-2xl transition-all duration-300 md:col-span-2 lg:col-span-1">
        <figure class="overflow-hidden">
          <img src="https://placehold.co/400x250/8b5cf6/ffffff?text=Singapore+Family" alt="Singapore Family Vacation" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-300">
        </figure>
        <div class="card-body p-6">
          <h3 class="card-title text-slate-900 text-xl mb-2">Singapore Family Vacation</h3>
          <p class="text-slate-600 mb-4">Family-friendly attractions, world-class dining, and educational experiences in the Lion City</p>
          <div class="flex items-center justify-between">
            <span class="badge badge-info">Family</span>
            <span class="text-sm text-slate-500">5 Days</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Our Approach</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">A proven 5-step process that ensures every journey exceeds expectations</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
      <div class="text-center group">
        <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-white font-bold text-xl">1</span>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">Discovery</h3>
        <p class="text-slate-600 text-sm">Understanding your dreams, preferences, and travel goals</p>
      </div>

      <div class="text-center group">
        <div class="w-16 h-16 bg-secondary rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-white font-bold text-xl">2</span>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">Design</h3>
        <p class="text-slate-600 text-sm">Crafting a personalized itinerary tailored to your vision</p>
      </div>

      <div class="text-center group">
        <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-white font-bold text-xl">3</span>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">Coordination</h3>
        <p class="text-slate-600 text-sm">Seamless booking and arrangement of all travel components</p>
      </div>

      <div class="text-center group">
        <div class="w-16 h-16 bg-info rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-white font-bold text-xl">4</span>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">Experience</h3>
        <p class="text-slate-600 text-sm">24/7 support during your journey for peace of mind</p>
      </div>

      <div class="text-center group">
        <div class="w-16 h-16 bg-success rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-white font-bold text-xl">5</span>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">Follow-up</h3>
        <p class="text-slate-600 text-sm">Gathering feedback to continuously improve our service</p>
      </div>
    </div>
  </div>
</section>

<section class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">What Our Travelers Say</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">Real experiences from real travelers who trusted us with their dream vacations</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="card bg-white shadow-xl border border-slate-100 rounded-2xl p-6">
        <div class="flex items-center mb-4">
          <div class="avatar">
            <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center">
              <span class="text-white font-semibold">SM</span>
            </div>
          </div>
          <div class="ml-4">
            <h4 class="font-semibold text-slate-900">Sarah Mitchell</h4>
            <p class="text-sm text-slate-600">Bali Luxury Escape</p>
          </div>
        </div>
        <div class="rating rating-sm mb-3">
          <input type="radio" name="rating-1" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-1" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-1" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-1" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-1" class="mask mask-star-2 bg-orange-400" checked />
        </div>
        <p class="text-slate-600">"Absolutely incredible experience! Every detail was perfectly planned. The villa was stunning and the cultural tours were enlightening. Priyaan made our dream vacation a reality."</p>
      </div>

      <div class="card bg-white shadow-xl border border-slate-100 rounded-2xl p-6">
        <div class="flex items-center mb-4">
          <div class="avatar">
            <div class="w-12 h-12 rounded-full bg-secondary flex items-center justify-center">
              <span class="text-white font-semibold">JR</span>
            </div>
          </div>
          <div class="ml-4">
            <h4 class="font-semibold text-slate-900">James Rodriguez</h4>
            <p class="text-sm text-slate-600">Maldives Honeymoon</p>
          </div>
        </div>
        <div class="rating rating-sm mb-3">
          <input type="radio" name="rating-2" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-2" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-2" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-2" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-2" class="mask mask-star-2 bg-orange-400" checked />
        </div>
        <p class="text-slate-600">"Our honeymoon was magical beyond words. The overwater bungalow, private dinners, and sunset cruises created memories we'll treasure forever. Thank you for making it perfect!"</p>
      </div>

      <div class="card bg-white shadow-xl border border-slate-100 rounded-2xl p-6">
        <div class="flex items-center mb-4">
          <div class="avatar">
            <div class="w-12 h-12 rounded-full bg-accent flex items-center justify-center">
              <span class="text-white font-semibold">LT</span>
            </div>
          </div>
          <div class="ml-4">
            <h4 class="font-semibold text-slate-900">Lisa Thompson</h4>
            <p class="text-sm text-slate-600">Singapore Family Trip</p>
          </div>
        </div>
        <div class="rating rating-sm mb-3">
          <input type="radio" name="rating-3" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-3" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-3" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-3" class="mask mask-star-2 bg-orange-400" checked />
          <input type="radio" name="rating-3" class="mask mask-star-2 bg-orange-400" checked />
        </div>
        <p class="text-slate-600">"Traveling with kids can be stressful, but Priyaan made it seamless. Every activity was age-appropriate and engaging. The kids are already asking when we can go back!"</p>
      </div>
    </div>
  </div>
</section>

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Why Choose Priyaan</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">Our commitment to excellence sets us apart in creating extraordinary travel experiences</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="text-center group">
        <div class="w-20 h-20 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-primary/20 transition-colors duration-300">
          <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">Expert Planning</h3>
        <p class="text-slate-600 text-sm">Years of experience crafting perfect itineraries</p>
      </div>

      <div class="text-center group">
        <div class="w-20 h-20 bg-secondary/10 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-secondary/20 transition-colors duration-300">
          <svg class="w-10 h-10 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">Personalized Service</h3>
        <p class="text-slate-600 text-sm">Tailored experiences that match your unique style</p>
      </div>

      <div class="text-center group">
        <div class="w-20 h-20 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-accent/20 transition-colors duration-300">
          <svg class="w-10 h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">24/7 Support</h3>
        <p class="text-slate-600 text-sm">Round-the-clock assistance during your travels</p>
      </div>

      <div class="text-center group">
        <div class="w-20 h-20 bg-success/10 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-success/20 transition-colors duration-300">
          <svg class="w-10 h-10 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 mb-2">Premium Quality</h3>
        <p class="text-slate-600 text-sm">Only the finest accommodations and experiences</p>
      </div>
    </div>

    <div class="text-center mt-12">
      <a href="/contact" class="btn btn-primary btn-lg">Start Planning Your Journey</a>
    </div>
  </div>
</section>
</Layout>