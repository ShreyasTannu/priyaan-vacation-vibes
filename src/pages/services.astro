---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Services & Packages">
<section class="bg-primary text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Our Travel Services</h1>
      <p class="text-xl text-blue-100 max-w-3xl mx-auto">Discover our comprehensive range of travel services designed to make your journey unforgettable. From customized packages to luxury experiences, we've got you covered.</p>
    </div>
  </div>
</section>

<section class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Service 1: Customized Holiday Packages -->
    <div class="grid lg:grid-cols-2 gap-12 items-center mb-20">
      <div class="order-2 lg:order-1">
        <div class="card bg-white shadow-xl border border-slate-100 rounded-2xl p-8 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300">
          <h2 class="text-3xl font-bold text-slate-900 mb-6">Customized Holiday Packages</h2>
          <p class="text-lg text-slate-600 mb-6">Tailored travel experiences designed specifically for your preferences, budget, and timeline. Our expert team crafts unique itineraries that reflect your travel dreams.</p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 bg-primary rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <span class="text-slate-700">Personalized itinerary planning</span>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 bg-primary rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <span class="text-slate-700">Flexible booking options</span>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 bg-primary rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <span class="text-slate-700">24/7 travel support</span>
            </li>
          </ul>
          <a href="/contact" class="btn btn-primary btn-lg">Get Custom Quote</a>
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <div class="overflow-hidden rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300">
          <img src="https://placehold.co/600x400/0ea5e9/ffffff?text=Custom+Packages" alt="Customized Holiday Packages" class="w-full h-auto object-cover hover:scale-105 transition-transform duration-300">
        </div>
      </div>
    </div>

    <!-- Service 2: International Travel -->
    <div class="grid lg:grid-cols-2 gap-12 items-center mb-20">
      <div class="order-1">
        <div class="overflow-hidden rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300">
          <img src="https://placehold.co/600x400/0ea5e9/ffffff?text=International+Travel" alt="International Travel" class="w-full h-auto object-cover hover:scale-105 transition-transform duration-300">
        </div>
      </div>
      <div class="order-2">
        <div class="card bg-white shadow-xl border border-slate-100 rounded-2xl p-8 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300">
          <h2 class="text-3xl font-bold text-slate-900 mb-6">International Travel</h2>
          <p class="text-lg text-slate-600 mb-6">Explore the world with our comprehensive international travel services. From exotic destinations to popular tourist spots, we make global travel seamless and memorable.</p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-4">
