<section class="py-16 bg-primary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Ready to Start Your Journey?</h2>
    <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">Contact our travel experts today to discuss your travel needs and let us create the perfect experience for you.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/contact" class="btn btn-secondary btn-lg">Get Started Today</a>
      <a href="/experiences" class="btn btn-outline btn-lg text-white border-white hover:bg-white hover:text-primary">View Experiences</a>
    </div>
