                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <span class="text-slate-700">Travel insurance coverage</span>
            </li>
          </ul>
          <a href="/experiences" class="btn btn-primary btn-lg">Explore Destinations</a>
        </div>
      </div>
    </div>

    <!-- Service 3: Domestic Experiences -->
    <div class="grid lg:grid-cols-2 gap-12 items-center mb-20">
      <div class="order-2 lg:order-1">
        <div class="card bg-white shadow-xl border border-slate-100 rounded-2xl p-8 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300">
