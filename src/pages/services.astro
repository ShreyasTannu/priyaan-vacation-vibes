    <!-- Service 6: Visa Assistance -->
    <div class="grid lg:grid-cols-2 gap-12 items-center mb-20">
      <div class="order-1">
        <div class="overflow-hidden rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300">
          <img src="https://placehold.co/600x400/0ea5e9/ffffff?text=Visa+Services" alt="Visa Assistance" class="w-full h-auto object-cover hover:scale-105 transition-transform duration-300">
